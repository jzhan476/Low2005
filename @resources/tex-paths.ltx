% LaTeX path configuration for this repository.
% kpathsea (TEXINPUTS with //) resolves packages under tex/latex subdirectories;
% reproduce scripts and .latexmkrc set TEXINPUTS accordingly.

\makeatletter
\def\input@path{{@resources/texlive/texmf-local/tex/latex/}%
  ,{@resources/texlive/texmf-local/bibtex/bst/}%
  ,{@resources/texlive/texmf-local/bibtex/bib/}%
  ,{@local/}%
  ,{../@resources/texlive/texmf-local/tex/latex/}%
  ,{../@resources/texlive/texmf-local/bibtex/bst/}%
  ,{../@resources/texlive/texmf-local/bibtex/bib/}%
  ,{../@local/}%
  ,{../}%
}
\makeatother

% BibTeX search is via BIBINPUTS/BSTINPUTS in reproduce scripts (not \input@path).
\input{\latexroot/@local/_inputpaths.ltx}
